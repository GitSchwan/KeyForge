<Styles xmlns="https://github.com/avaloniaui"
            xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
            xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
            mc:Ignorable="d"
            xmlns:d="http://schemas.microsoft.com/expression/blend/2008">
    
    <Style Selector="Border#CustomTitleBar">
        <Setter Property="Background" Value="{DynamicResource Brush.Secondary}"/>
        
    </Style>
    
    <Style Selector="TextBlock">
        <Setter Property="Foreground" Value="{DynamicResource Brush.Foreground}"/>
    </Style>
    
    <Style Selector="Label">
        <Setter Property="Foreground" Value="{DynamicResource Brush.Foreground}"/>
    </Style>
    
    <Style Selector="Path">
        <Setter Property="Stroke" Value="{DynamicResource Brush.Primary}"/>
    </Style>
    
    <Style Selector="Button">
        <Setter Property="Foreground" Value="{DynamicResource Brush.Foreground}"/>
    </Style>
    
    <Style Selector="Button:pointerover">
        <Setter Property="Background" Value="#444"/>
        <Setter Property="Foreground" Value="{DynamicResource Brush.Foreground}"/>
    </Style>

    <Style Selector="Button:pressed">
        <Setter Property="Background" Value="#666"/>
        <Setter Property="Foreground" Value="{DynamicResource Brush.Foreground}"/>
    </Style>
    
    <Style Selector="Separator">
        <Setter Property="Foreground" Value="{DynamicResource Brush.Foreground}"/>
    </Style>

</Styles>