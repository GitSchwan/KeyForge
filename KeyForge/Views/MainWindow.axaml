<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:KeyForge.ViewModels"
        xmlns:views="using:KeyForge.Views"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        Background="Transparent"
        Width="1000"
        Height="600"
        TransparencyLevelHint="AcrylicBlur"
        ExtendClientAreaToDecorationsHint="False"
        mc:Ignorable="d" d:DesignWidth="640" d:DesignHeight="460"
        CanResize="False"
        x:Class="KeyForge.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Icon="/Assets/anvil.ico"
        Title="KeyForge">

    <Window.DataTemplates>
        <DataTemplate DataType="vm:LoginViewModel">
            <views:LoginView />
        </DataTemplate>

        <DataTemplate DataType="vm:HomeViewModel">
            <views:HomeView />
        </DataTemplate>
        
        <DataTemplate DataType="vm:AddViewModel">
            <views:AddView/>
        </DataTemplate>
    </Window.DataTemplates>

    <ContentControl Content="{Binding CurrentViewModel}" />
</Window>
