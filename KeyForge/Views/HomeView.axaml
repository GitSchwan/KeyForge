<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:KeyForge.ViewModels"
             xmlns:models="clr-namespace:KeyForge.Models"
             x:Class="KeyForge.Views.HomeView"
             x:Name="Root"
             x:DataType="vm:HomeViewModel">
    <StackPanel>
        <Border Background="#80000000">
            <Grid ShowGridLines="False"
                  Margin="0,0,0,0"
                  ColumnDefinitions="Auto, *, Auto, Auto"
                  RowDefinitions="Auto">

                <TextBlock Grid.Column="0"
                           Text="KeyForge"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           FontSize="44"
                           Margin="20,0,0,20"/>

                <Button Grid.Column="2"
                        Command="{Binding NavigateToAddCommand}"
                        Margin="10,0,10,0"
                        Content="+Add"/>

                <Button Grid.Column="3"
                        Margin="10,0,10,0"
                        Content="⚙"/>

            </Grid>
        </Border>

        <Grid ShowGridLines="False"
              HorizontalAlignment="Center"
              ColumnDefinitions="Auto, Auto"
              RowDefinitions="Auto, Auto"
              Margin="0,10,0,0">

            <TextBlock Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="2"
                       Text="{Binding WelcomeMessage}"
                       FontSize="35"
                       HorizontalAlignment="Center"
                       Margin="0,0,0,30"/>

            <DataGrid Grid.Row="1" Grid.Column="1"
                      ItemsSource="{Binding Data}"
                      IsReadOnly="False"
                      GridLinesVisibility="All"
                      BorderThickness="1"
                      Width="600"
                      RowHeight="42"
                      BorderBrush="SlateGray"
                      Background="#80000000">

                <DataGrid.Columns>
                    <DataGridTextColumn Header="Webseite" Binding="{Binding Website}"/>
                    <DataGridTextColumn Header="Nutzername" Binding="{Binding Websiteusername}"/>
                    <DataGridTextColumn Width="200" Header="Passwort" Binding="{Binding Password}" IsReadOnly="True"/>
                    
                    <DataGridTemplateColumn Header="Speichern">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Button Content="✔"
                                        IsVisible="{Binding IsModified}"
                                        Command="{Binding SaveCommand}"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center"
                                        Background="#80000000"
                                        Foreground="White"
                                        BorderBrush="White"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                
                    <DataGridTemplateColumn Header="Löschen">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Button Content="X"
                                        Command="{Binding DeleteEntryCommand}"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center"
                                        Background="#80000000"
                                        Foreground="White"
                                        BorderBrush="White"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
        </Grid>
    </StackPanel>
</UserControl>