<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:KeyForge.ViewModels"
             x:Class="KeyForge.Views.LoginView"
             x:DataType="vm:LoginViewModel">
    
    <StackPanel>
        <Button Content="Neuer Nutzer"
                VerticalAlignment="Top"
                HorizontalAlignment="Right"
                Margin="5"
                Command="{Binding NavCreateUserCommand}"/>
        <StackPanel VerticalAlignment="Center" Margin="0,200,0,0" Width="300" HorizontalAlignment="Center" >
            <Border>
                <StackPanel>
                    <TextBlock Text="Passwort Manager"
                               HorizontalAlignment="Center"
                               TextWrapping="Wrap"
                               FontSize="24"
                               Margin="10"/>

                    <TextBlock Text="Username"
                               HorizontalAlignment="Left"/>

                    <TextBox Watermark="Bitte gib deinen Nutzernamen ein..."
                             Text="{Binding Username}"
                             Width="300"
                             HorizontalAlignment="Left"
                             Margin="0,10,0,0"/>

                    <TextBlock Text="Masterpasswort"
                               HorizontalAlignment="Left"
                               Margin="0,10,0,0"/>

                    <TextBox Watermark="Bitte gib dein Masterpasswort ein..."
                             Text="{Binding MasterPassword}"
                             Width="300"
                             PasswordChar="*"
                             HorizontalAlignment="Left"
                             Margin="0,10,0,0"/>

                    <Button Content="Einloggen"
                            HorizontalAlignment="Center"
                            Margin="10"
                            Command="{Binding LoginCommand}" />
                    
                </StackPanel>
            </Border>
        </StackPanel>
    </StackPanel>
</UserControl>
