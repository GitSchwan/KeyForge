<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:KeyForge.ViewModels"
             x:Class="KeyForge.Views.LoginView"
             x:DataType="vm:LoginViewModel">
    
    <StackPanel>
        <Button Content="Neuer Nutzer"
                VerticalAlignment="Top"
                HorizontalAlignment="Right"
                Cursor="Hand"
                Foreground="White"
                Margin="5"
                Command="{Binding NavCreateUserCommand}"/>
        <StackPanel VerticalAlignment="Center" 
                    Margin="0,150,0,0" 
                    Width="400" 
                    HorizontalAlignment="Center">
            
            
            <Grid Width="400"
                  HorizontalAlignment="Center"
                  VerticalAlignment="Center">

                <!-- Animated glow border -->
                <Border BorderBrush="White"
                        BorderThickness="2"
                        CornerRadius="10"
                        Opacity="0.3">

                    <Border.Styles>
                        <Style Selector="Border">
                            <Style.Animations>
                                <Animation Duration="0:0:4"
                                           IterationCount="INFINITE"
                                           PlaybackDirection="1">

                                    <KeyFrame Cue="0%">
                                        <Setter Property="Opacity" Value="0.2"/>
                                    </KeyFrame>

                                    <KeyFrame Cue="50%">
                                        <Setter Property="Opacity" Value="1"/>
                                    </KeyFrame>

                                    <KeyFrame Cue="100%">
                                        <Setter Property="Opacity" Value="0.2"/>
                                    </KeyFrame>

                                </Animation>
                            </Style.Animations>
                        </Style>
                    </Border.Styles>
                </Border>
                
                <Border CornerRadius="10"
                        Background="#70000000"
                        BoxShadow="0 0 10 0 rgba(255,255,255,0.8), 0 0 4 0 rgba(255,255,255,0.5)">
                
                <StackPanel>
                    <TextBlock Text="Anmelden"
                               HorizontalAlignment="Center"
                               TextWrapping="Wrap"
                               FontSize="24"
                               Margin="10"
                               Foreground="White"
                               />

                    <Label Content="Nutzername"
                           Target="UsernameBox"
                           HorizontalAlignment="Left"
                           Margin="50,0,0,0"
                           Foreground="White"/>

                    <TextBox Watermark="Bitte gib deinen Nutzernamen ein..."
                             Text="{Binding Username}"
                             Width="300"
                             x:Name="UsernameBox"
                             HorizontalAlignment="Left"
                             Margin="50,10,0,0"
                             Foreground="White"/>

                    <Label Content="Masterpasswort"
                           Target="PasswordBox"
                           HorizontalAlignment="Left"
                           Margin="50,10,0,0"
                           Foreground="White"/>

                    <TextBox x:Name="PasswordBox"
                             Watermark="Bitte gib dein Masterpasswort ein..."
                             Text="{Binding MasterPassword}"
                             Width="300"
                             PasswordChar="*"
                             HorizontalAlignment="Left"
                             Margin="50,10,0,0"
                             Foreground="White">
                        <TextBox.InnerRightContent>
                            <ToggleButton 
                                Content="👁" 
                                IsChecked="{Binding #PasswordBox.RevealPassword}"
                                VerticalAlignment="Center"
                                Foreground="White"/>
                        </TextBox.InnerRightContent>
                        
                    </TextBox>
                    
                    <Button Content="Einloggen"
                            HorizontalAlignment="Center"
                            Margin="10"
                            HotKey="Return"
                            Cursor="Hand"
                            Command="{Binding LoginCommand}" 
                            Foreground="White"/>
                    
                </StackPanel>
            </Border>
            </Grid>
        </StackPanel>
    </StackPanel>
</UserControl>
