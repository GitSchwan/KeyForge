<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:KeyForge.ViewModels"
             x:Class="KeyForge.Views.LoginView"
             x:DataType="vm:LoginViewModel">
    
    <StackPanel>
        <Button Content="Neuer Nutzer"
                VerticalAlignment="Top"
                HorizontalAlignment="Right"
                Cursor="Hand"
                Margin="5"
                Command="{Binding NavCreateUserCommand}"/>
        <StackPanel VerticalAlignment="Center" 
                    Margin="0,150,0,0" 
                    Width="400" 
                    HorizontalAlignment="Center">
            <Border Width="400" HorizontalAlignment="Center" VerticalAlignment="Center" CornerRadius="10" Background="#30000000">
                <StackPanel>
                    <TextBlock Text="Anmelden"
                               HorizontalAlignment="Center"
                               TextWrapping="Wrap"
                               FontSize="24"
                               Margin="10"/>

                    <Label Content="Nutzername"
                           Target="UsernameBox"
                           HorizontalAlignment="Left"
                           Margin="50,0,0,0"/>

                    <TextBox Watermark="Bitte gib deinen Nutzernamen ein..."
                             Text="{Binding Username}"
                             Width="300"
                             x:Name="UsernameBox"
                             HorizontalAlignment="Left"
                             Margin="50,10,0,0"/>

                    <Label Content="Masterpasswort"
                           Target="PasswordBox"
                           HorizontalAlignment="Left"
                           Margin="50,10,0,0"/>

                    <TextBox x:Name="PasswordBox"
                             Watermark="Bitte gib dein Masterpasswort ein..."
                             Text="{Binding MasterPassword}"
                             Width="300"
                             PasswordChar="*"
                             HorizontalAlignment="Left"
                             Margin="50,10,0,0">
                        <TextBox.InnerRightContent>
                            <ToggleButton 
                                Content="👁" 
                                IsChecked="{Binding #PasswordBox.RevealPassword}"
                                VerticalAlignment="Center"/>
                        </TextBox.InnerRightContent>
                        
                    </TextBox>
                    
                    <Button Content="Einloggen"
                            HorizontalAlignment="Center"
                            Margin="10"
                            HotKey="Return"
                            Cursor="Hand"
                            Command="{Binding LoginCommand}" />
                    
                </StackPanel>
            </Border>
        </StackPanel>
    </StackPanel>
</UserControl>
