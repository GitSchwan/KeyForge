<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:KeyForge.ViewModels"
             x:Class="KeyForge.Views.LoginView"
             x:DataType="vm:LoginViewModel">
    
    <StackPanel>
        <Button Content="Neuer Nutzer"
                VerticalAlignment="Top"
                HorizontalAlignment="Right"
                Cursor="Hand"
                Foreground="White"
                Margin="5"
                Command="{Binding NavCreateUserCommand}"/>
        <StackPanel VerticalAlignment="Center" 
                    Margin="0,150,0,0" 
                    Width="400" 
                    HorizontalAlignment="Center">
            
            
            <Grid Width="400"
                  HorizontalAlignment="Center"
                  VerticalAlignment="Center">

                <Border CornerRadius="10"
                        Background="#70000000"
                        BorderThickness="2">

                    <Border.Styles>
                        <Style Selector="Border">
                            <Setter Property="BorderBrush" Value="Cyan"/>

                            <Style.Animations>
                                <Animation Duration="0:0:40"
                                           IterationCount="INFINITE">

                                    <KeyFrame Cue="0%">
                                        <Setter Property="BorderBrush" Value="Cyan"/>
                                    </KeyFrame>

                                    <KeyFrame Cue="16.66%">
                                        <Setter Property="BorderBrush" Value="Magenta"/>
                                    </KeyFrame>

                                    <KeyFrame Cue="33.33%">
                                        <Setter Property="BorderBrush" Value="Yellow"/>
                                    </KeyFrame>

                                    <KeyFrame Cue="50%">
                                        <Setter Property="BorderBrush" Value="Lime"/>
                                    </KeyFrame>

                                    <KeyFrame Cue="66.66%">
                                        <Setter Property="BorderBrush" Value="Orange"/>
                                    </KeyFrame>

                                    <KeyFrame Cue="83.33%">
                                        <Setter Property="BorderBrush" Value="Red"/>
                                    </KeyFrame>

                                    <KeyFrame Cue="100%">
                                        <Setter Property="BorderBrush" Value="Cyan"/>
                                    </KeyFrame>

                                </Animation>
                            </Style.Animations>
                        </Style>
                    </Border.Styles>

                <StackPanel>
                    <TextBlock Text="Anmelden"
                               HorizontalAlignment="Center"
                               TextWrapping="Wrap"
                               FontSize="24"
                               Margin="10"
                               Foreground="White"
                               />

                    <Label Content="Nutzername"
                           Target="UsernameBox"
                           HorizontalAlignment="Left"
                           Margin="50,0,0,0"
                           Foreground="White"/>

                    <TextBox Watermark="Bitte gib deinen Nutzernamen ein..."
                             Text="{Binding Username}"
                             Width="300"
                             x:Name="UsernameBox"
                             HorizontalAlignment="Left"
                             Margin="50,10,0,0"
                             Foreground="White"/>

                    <Label Content="Masterpasswort"
                           Target="PasswordBox"
                           HorizontalAlignment="Left"
                           Margin="50,10,0,0"
                           Foreground="White"/>

                    <TextBox x:Name="PasswordBox"
                             Watermark="Bitte gib dein Masterpasswort ein..."
                             Text="{Binding MasterPassword}"
                             Width="300"
                             PasswordChar="*"
                             HorizontalAlignment="Left"
                             Margin="50,10,0,0"
                             Foreground="White">
                        <TextBox.InnerRightContent>
                            <ToggleButton 
                                Content="👁" 
                                IsChecked="{Binding #PasswordBox.RevealPassword}"
                                VerticalAlignment="Center"
                                Foreground="White"/>
                        </TextBox.InnerRightContent>
                        
                    </TextBox>
                    
                    <Button Content="Einloggen"
                            HorizontalAlignment="Center"
                            Margin="10"
                            HotKey="Return"
                            Cursor="Hand"
                            Command="{Binding LoginCommand}" 
                            Foreground="White"/>
                    
                </StackPanel>
            </Border>
            </Grid>
        </StackPanel>
    </StackPanel>
</UserControl>
